{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "multitask",
        "multitask-tui.tsx",
        "workspace-tui.tsx",
        "auto-switch-mode.ts"
    ],
    "mcp": {
        "office-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/OpencodePortable/scripts/office_mcp.py"
            ],
            "enabled": true
        },
        "project-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/OpencodePortable/scripts/project_generator.py"
            ],
            "enabled": true
        }
    }
}
