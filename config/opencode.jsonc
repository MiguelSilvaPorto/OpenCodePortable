{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        [
            "@renjfk/opencode-voice",
            {
                "endpoint": "http://localhost:11434/v1",
                "model": "llama3.2",
                "apiKeyEnv": "GROQ_API_KEY",
                "sttEndpoint": "https://api.groq.com/openai/v1",
                "sttModel": "whisper-large-v3-turbo",
                "sttApiKeyEnv": "GROQ_API_KEY"
            }
        ],
        "workspace-tui.tsx",
        "auto-switch-mode.ts"
    ],
    "mcp": {
        "office-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/OpenCodePortable/scripts/office_mcp.py"
            ],
            "enabled": true
        },
        "project-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/OpenCodePortable/scripts/project_generator.py"
            ],
            "enabled": true
        },
        "brain-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/OpenCodePortable/.brain/scripts/brain_mcp.py"
            ],
            "enabled": true
        }
    }
}