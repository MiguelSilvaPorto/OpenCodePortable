{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        [
            "@renjfk/opencode-voice",
            {
                "endpoint": "https://api.groq.com/openai/v1",
                "model": "llama-3.3-70b-versatile",
                "apiKeyEnv": "GROQ_API_KEY"
            }
        ]
    ],
    "mcp": {
        "office-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/Scrath/scripts/office_mcp.py"
            ],
            "enabled": true
        },
        "project-mcp": {
            "type": "local",
            "command": [
                "python",
                "D:/Github/Scrath/scripts/project_generator.py"
            ],
            "enabled": true
        }
    }
}
