# Opencode Portable Git Ignore

# Runtime data (generated locally)
data/

# Worktrees
worktree/
.opencode/worktrees/

# Config secrets (user-specific)
config/opencode.json
config/opencode/account.json
config/opencode/auth.json
config/opencode/node_modules/
config/opencode/plugins/
config/opencode/skills/
.opencode/opencode.json

# Logs
*.log
data/logs/

# Test sandbox (regenerated by tests)
tests/sandbox/

# Binary (too large for git)
bin/opencode.exe

# Python cache (regenerated automatically)
__pycache__/
*.pyc
*.pyo
*.pyd
.python-version

# Root-level installer stubs (created by install scripts)
# Real binaries live in bin/ and are explicitly allowed
/*.exe
/*.dll
/*.bat.tmp

# Generated build outputs (regenerated by scripts)
output/
preview/

# Temporary extractions (one-off unzips)
extracted_*/
*.zip.tmp

# Installer executables (regenerated by build scripts)
installers/
# Tool/IDE dirs
.gemini/
.local/
.cache/
.config/

# Project local workspace settings
.opencode/workspace.json

# Version cache (regenerated automatically)
data/version.cache

# User local projects
Projects/

# Local environment files (may contain API keys)
config/.env
.env
.env.local

scripts/apps-config.ini
